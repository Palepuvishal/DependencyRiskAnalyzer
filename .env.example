# Neo4j Aura connection (required)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-password

# Backend port (optional, defaults to 3001)
PORT=3001

# Frontend will call this URL from the browser
# In Docker: use http://localhost:3001 (host-side port)
# In production: use your actual backend domain
NEXT_PUBLIC_API_URL=http://localhost:3001
